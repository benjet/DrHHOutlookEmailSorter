{
  "name": "outlook-inbox-sorter",
  "version": "1.0.0",
  "description": "Browser-based Outlook Inbox Category Sorter using Playwright",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dry-run": "cross-env DRY_RUN=true node src/index.js",
    "verify": "node src/verify.js",
    "verify:dry": "cross-env DRY_RUN=true node src/verify.js",
    "catch-missed": "node src/catch-missed.js",
    "catch-missed:dry": "cross-env DRY_RUN=true node src/catch-missed.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "playwright": "^1.50.0"
  }
}
